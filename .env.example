# Environment variables for Mberede
# Copy this file to .env and fill in your values

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration
DATABASE_URL=sqlite:///./mberede.db
# For PostgreSQL (Phase 2+):
# DATABASE_URL=postgresql://user:password@localhost:5432/mberede

# SMS Configuration - Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SMS Configuration - Africa's Talking
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_USERNAME=your_africas_talking_username

# VoIP Configuration (uses same Twilio/Africa's Talking account as SMS)
# Twilio: Enable Voice in your Twilio console and set the same account credentials
# Africa's Talking: Enable Voice product in your Africa's Talking dashboard
VOIP_PROVIDER=twilio  # 'twilio' or 'africas_talking'

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
PIN_ROUNDS=12

# Rate Limiting
MAX_PIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
PROGRESSIVE_DELAY_SECONDS=2

# Session
SESSION_TTL_MINUTES=10

# Admin Configuration
# Comma-separated Telegram user IDs that can access admin commands
# Get your ID by sending /myid to the bot
ADMIN_TELEGRAM_IDS=your_admin_telegram_id_here

# Logging
LOG_LEVEL=INFO
